{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VLMRenderReview",
  "description": "Schema version vlm_review_v1 \u2014 output of Qwen3.5-35B-A3B render quality review",
  "type": "object",
  "required": [
    "schema_version",
    "sample_id",
    "round_idx",
    "vlm_route",
    "scores",
    "confidence",
    "issue_tags",
    "suggested_actions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "vlm_review_v1"
    },
    "sample_id": {
      "type": "string"
    },
    "round_idx": {
      "type": "integer",
      "minimum": 0
    },
    "vlm_route": {
      "type": "string",
      "enum": [
        "pass",
        "needs_fix",
        "reject"
      ]
    },
    "scores": {
      "type": "object",
      "required": [
        "lighting",
        "object_integrity",
        "composition",
        "render_quality_semantic",
        "overall"
      ],
      "properties": {
        "lighting": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "object_integrity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "composition": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "render_quality_semantic": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "overall": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "confidence": {
      "type": "object",
      "required": [
        "lighting",
        "object_integrity",
        "composition",
        "render_quality_semantic",
        "overall"
      ],
      "properties": {
        "lighting": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "object_integrity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "composition": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "render_quality_semantic": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "overall": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "issue_tags": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "none",
          "underexposed",
          "overexposed",
          "flat_lighting",
          "harsh_shadow",
          "weak_subject_separation",
          "background_too_bright",
          "background_too_dark",
          "object_too_small",
          "object_too_large",
          "off_center_left",
          "off_center_right",
          "off_center_up",
          "off_center_down",
          "object_cutoff_left",
          "object_cutoff_right",
          "object_cutoff_top",
          "object_cutoff_bottom",
          "floating_object",
          "ground_intersection",
          "geometry_distortion",
          "partial_occlusion",
          "mask_boundary_error",
          "mask_hole",
          "mask_spill",
          "background_distracting",
          "depth_of_field_too_strong",
          "depth_of_field_too_weak",
          "mesh_interpenetration",
          "color_shift",
          "physical_implausibility",
          "scene_light_mismatch",
          "shadow_missing",
          "scale_implausible",
          "floating_visible",
          "ground_intersection_visible"
        ]
      }
    },
    "suggested_actions": {
      "type": "array",
      "maxItems": 2,
      "items": {
        "type": "string",
        "enum": [
          "NO_OP",
          "L_KEY_UP",
          "L_KEY_DOWN",
          "L_FILL_UP",
          "L_FILL_DOWN",
          "L_RIM_UP",
          "L_RIM_DOWN",
          "L_WORLD_EV_UP",
          "L_WORLD_EV_DOWN",
          "L_KEY_SHADOW_SOFT",
          "L_KEY_SHADOW_HARD",
          "C_DOLLY_IN",
          "C_DOLLY_OUT",
          "C_PAN_LEFT",
          "C_PAN_RIGHT",
          "C_TILT_UP",
          "C_TILT_DOWN",
          "C_FOV_NARROW",
          "C_FOV_WIDE",
          "O_SHIFT_LEFT",
          "O_SHIFT_RIGHT",
          "O_SHIFT_UP",
          "O_SHIFT_DOWN",
          "O_LIFT",
          "O_LOWER",
          "O_SCALE_UP",
          "O_SCALE_DOWN",
          "S_BG_BRIGHTER",
          "S_BG_DARKER",
          "S_BG_CONTRAST_UP",
          "S_BG_CONTRAST_DOWN",
          "S_CONTACT_SHADOW_UP",
          "S_CONTACT_SHADOW_DOWN",
          "S_DOF_STRONGER",
          "S_DOF_WEAKER",
          "M_SATURATION_DOWN",
          "M_VALUE_UP",
          "L_RIM_FILL_UP",
          "L_RIM_SHADOW_SOFT",
          "L_KEY_FILL_UP",
          "O_LIFT_SMALL",
          "O_LOWER_SMALL",
          "O_ROTATE_Z_POS_15",
          "O_ROTATE_Z_NEG_15",
          "O_SCALE_UP_10",
          "O_SCALE_DOWN_10",
          "ENV_ROTATE_30",
          "ENV_ROTATE_NEG_30",
          "ENV_STRENGTH_UP",
          "ENV_STRENGTH_DOWN",
          "L_KEY_YAW_POS_15",
          "L_KEY_YAW_NEG_15",
          "M_ROUGHNESS_UP"
        ]
      }
    },
    "lighting_diagnosis": {
      "type": "string",
      "enum": [
        "flat_no_rim",
        "flat_low_contrast",
        "underexposed_global",
        "underexposed_shadow",
        "harsh_shadow_key",
        "scene_light_mismatch",
        "shadow_missing",
        "good"
      ]
    },
    "structure_consistency": {
      "type": "string",
      "enum": [
        "good",
        "minor_mismatch",
        "major_mismatch"
      ]
    },
    "color_consistency": {
      "type": "string",
      "enum": [
        "good",
        "minor_shift",
        "major_shift"
      ]
    },
    "physics_consistency": {
      "type": "string",
      "enum": [
        "good",
        "minor_issue",
        "major_issue"
      ]
    },
    "pairwise_vs_prev": {
      "type": "object",
      "properties": {
        "available": {
          "type": "boolean"
        },
        "winner": {
          "type": "string",
          "enum": [
            "current",
            "previous",
            "tie",
            "none"
          ]
        },
        "lighting": {
          "type": "string",
          "enum": [
            "better",
            "same",
            "worse",
            "na"
          ]
        },
        "object_integrity": {
          "type": "string",
          "enum": [
            "better",
            "same",
            "worse",
            "na"
          ]
        },
        "composition": {
          "type": "string",
          "enum": [
            "better",
            "same",
            "worse",
            "na"
          ]
        },
        "render_quality_semantic": {
          "type": "string",
          "enum": [
            "better",
            "same",
            "worse",
            "na"
          ]
        }
      }
    }
  }
}

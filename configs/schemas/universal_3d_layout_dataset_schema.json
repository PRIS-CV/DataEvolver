{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataevolver.local/schemas/universal_3d_layout_dataset_schema.json",
  "title": "Universal 3D Layout / 3D Control Dataset Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "source_paper_signals",
    "prompt",
    "scene_graph",
    "objects",
    "camera",
    "layout_control",
    "render_artifacts",
    "validation",
    "loop_trace",
    "provenance",
    "promotion_decision"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "source_paper_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["paper_key", "paper_title", "arxiv_url", "signal"],
        "additionalProperties": false,
        "properties": {
          "paper_key": {"type": "string"},
          "paper_title": {"type": "string"},
          "arxiv_url": {"type": "string"},
          "signal": {"type": "string"}
        }
      }
    },
    "prompt": {
      "type": "object",
      "required": ["raw_text", "object_spans", "negative_constraints"],
      "additionalProperties": false,
      "properties": {
        "raw_text": {"type": "string"},
        "object_spans": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["object_id", "text_span"],
            "additionalProperties": false,
            "properties": {
              "object_id": {"type": "string"},
              "text_span": {"type": "string"}
            }
          }
        },
        "negative_constraints": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "scene_graph": {
      "type": "object",
      "required": ["nodes", "relations"],
      "additionalProperties": false,
      "properties": {
        "nodes": {"type": "array", "items": {"type": "string"}},
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["subject", "predicate", "object"],
            "additionalProperties": false,
            "properties": {
              "subject": {"type": "string"},
              "predicate": {"type": "string"},
              "object": {"type": "string"}
            }
          }
        }
      }
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "object_id",
          "category",
          "mesh_or_proxy",
          "bbox_3d",
          "orientation",
          "scale",
          "material"
        ],
        "additionalProperties": false,
        "properties": {
          "object_id": {"type": "string"},
          "category": {"type": "string"},
          "mesh_or_proxy": {"type": "string"},
          "bbox_3d": {
            "type": "object",
            "required": ["center_xyz", "size_xyz"],
            "additionalProperties": false,
            "properties": {
              "center_xyz": {"type": "array", "items": {"type": "number"}, "minItems": 3, "maxItems": 3},
              "size_xyz": {"type": "array", "items": {"type": "number"}, "minItems": 3, "maxItems": 3}
            }
          },
          "orientation": {
            "type": "object",
            "required": ["yaw_deg", "pitch_deg", "roll_deg"],
            "additionalProperties": false,
            "properties": {
              "yaw_deg": {"type": "number"},
              "pitch_deg": {"type": "number"},
              "roll_deg": {"type": "number"}
            }
          },
          "scale": {"type": "number"},
          "material": {"type": "string"}
        }
      }
    },
    "camera": {
      "type": "object",
      "required": ["viewpoint_token", "pose", "intrinsics", "relative_description"],
      "additionalProperties": false,
      "properties": {
        "viewpoint_token": {"type": "string"},
        "pose": {
          "type": "object",
          "required": ["azimuth_deg", "elevation_deg", "distance", "pitch_deg", "yaw_deg"],
          "additionalProperties": false,
          "properties": {
            "azimuth_deg": {"type": "number"},
            "elevation_deg": {"type": "number"},
            "distance": {"type": "number"},
            "pitch_deg": {"type": "number"},
            "yaw_deg": {"type": "number"}
          }
        },
        "intrinsics": {
          "type": "object",
          "required": ["focal_length_mm", "sensor_width_mm", "fov_deg"],
          "additionalProperties": false,
          "properties": {
            "focal_length_mm": {"type": "number"},
            "sensor_width_mm": {"type": "number"},
            "fov_deg": {"type": "number"}
          }
        },
        "relative_description": {"type": "string"}
      }
    },
    "layout_control": {
      "type": "object",
      "required": ["control_type", "spatial_relations", "depth_order", "occlusion_pairs"],
      "additionalProperties": false,
      "properties": {
        "control_type": {
          "type": "array",
          "items": {
            "enum": [
              "oscr",
              "3d_boxes",
              "mesh_scratchpad",
              "viewpoint_token",
              "relative_pose_pair",
              "sequential_3d_scene"
            ]
          }
        },
        "spatial_relations": {"type": "array", "items": {"type": "string"}},
        "depth_order": {"type": "array", "items": {"type": "string"}},
        "occlusion_pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["front_object", "behind_object", "visibility_note"],
            "additionalProperties": false,
            "properties": {
              "front_object": {"type": "string"},
              "behind_object": {"type": "string"},
              "visibility_note": {"type": "string"}
            }
          }
        }
      }
    },
    "render_artifacts": {
      "type": "object",
      "required": ["target_image", "structure_image", "masks", "depth", "normal"],
      "additionalProperties": false,
      "properties": {
        "target_image": {"type": "string"},
        "structure_image": {"type": "string"},
        "masks": {"type": "array", "items": {"type": "string"}},
        "depth": {"type": ["string", "null"]},
        "normal": {"type": ["string", "null"]}
      }
    },
    "edit_action": {
      "type": "object",
      "required": ["action_type", "before_state", "after_state", "preservation_targets"],
      "additionalProperties": false,
      "properties": {
        "action_type": {
          "enum": ["none", "insert", "delete", "move", "rotate", "reorient", "camera_shift", "background_keep"]
        },
        "before_state": {"type": ["string", "null"]},
        "after_state": {"type": ["string", "null"]},
        "preservation_targets": {"type": "array", "items": {"type": "string"}}
      }
    },
    "validation": {
      "type": "object",
      "required": ["geometry_checks", "mask_coverage", "occlusion_consistency", "vlm_score", "failure_tags"],
      "additionalProperties": false,
      "properties": {
        "geometry_checks": {"type": "array", "items": {"type": "string"}},
        "mask_coverage": {"type": "number"},
        "occlusion_consistency": {"type": "string"},
        "vlm_score": {"type": ["number", "null"]},
        "failure_tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "loop_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "critique", "repair_action", "accept"],
        "additionalProperties": false,
        "properties": {
          "candidate_id": {"type": "string"},
          "critique": {"type": "string"},
          "repair_action": {"type": "string"},
          "accept": {"type": "boolean"}
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["label", "source_paths"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "enum": [
            "official_downloaded",
            "official_result_recomputed",
            "self_generated",
            "synthetic_proxy",
            "mixed_reference"
          ]
        },
        "source_paths": {"type": "array", "items": {"type": "string"}}
      }
    },
    "promotion_decision": {
      "type": "object",
      "required": ["status", "reason"],
      "additionalProperties": false,
      "properties": {
        "status": {"enum": ["accepted", "rejected", "needs_repair", "reference_only"]},
        "reason": {"type": "string"}
      }
    }
  }
}
